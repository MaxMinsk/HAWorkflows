{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "WorkflowStorage": {
    "DatabasePath": "data/workflow.db"
  },
  "WorkflowArtifacts": {
    "WorkspacePath": "data/workspace"
  },
  "WorkflowRuns": {
    "CheckpointPath": "data/run-checkpoints",
    "ExternalSignalSuppressionWindowSeconds": 300
  },
  "WorkflowAgents": {
    "DefaultProfile": "echo",
    "Profiles": {
      "echo": {
        "Adapter": "echo"
      },
      "local_claude_code": {
        "Adapter": "local",
        "Settings": {
          "agentType": "claude_code",
          "executable": "claude",
          "timeoutSeconds": "600"
        }
      },
      "local_cursor": {
        "Adapter": "local",
        "Settings": {
          "agentType": "cursor",
          "executable": "cursor",
          "timeoutSeconds": "600"
        }
      }
    }
  },
  "WorkflowMcp": {
    "ConfigPath": "data/mcp.json",
    "DefaultProfile": "mock",
    "Profiles": {
      "mock": {
        "Type": "mock",
        "TimeoutSeconds": 30
      }
    }
  },
  "WorkflowModelRouting": {
    "DefaultPolicy": "agent_task",
    "Policies": {
      "agent_task": {
        "DefaultTier": "medium",
        "DefaultModel": "echo-medium",
        "DefaultAgentProfile": "echo",
        "ThinkingMode": "auto",
        "EscalationTier": "heavy",
        "EscalationModel": "echo-heavy",
        "EscalationAgentProfile": "echo",
        "FallbackTier": "cheap",
        "FallbackModel": "echo-cheap",
        "FallbackAgentProfile": "echo",
        "ConfidenceEscalationThreshold": 0.6,
        "RetryEscalationThreshold": 2,
        "BudgetFallbackThreshold": 0.1
      },
      "cheap_discover": {
        "DefaultTier": "cheap",
        "DefaultModel": "echo-cheap",
        "DefaultAgentProfile": "echo",
        "ThinkingMode": "off",
        "EscalationTier": "medium",
        "EscalationModel": "echo-medium",
        "EscalationAgentProfile": "echo",
        "FallbackTier": "cheap",
        "FallbackModel": "echo-cheap",
        "FallbackAgentProfile": "echo",
        "ConfidenceEscalationThreshold": 0.55,
        "RetryEscalationThreshold": 2,
        "BudgetFallbackThreshold": 0.1
      },
      "heavy_plan": {
        "DefaultTier": "heavy",
        "DefaultModel": "echo-heavy",
        "DefaultAgentProfile": "echo",
        "ThinkingMode": "on",
        "FallbackTier": "medium",
        "FallbackModel": "echo-medium",
        "FallbackAgentProfile": "echo",
        "BudgetFallbackThreshold": 0.1
      }
    }
  },
  "WorkflowNodes": {
    "EnabledPacks": [],
    "DisabledPacks": []
  },
  "AllowedHosts": "*"
}
